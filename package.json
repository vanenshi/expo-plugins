{
  "name": "@vanenshi/expo-plugins",
  "version": "0.1.0",
  "description": "A small collection of Expo config plugins.",
  "license": "MIT",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "files": [
